void main() 
{
    vec3 id = gl_GlobalInvocationID;
    float x = id.x * Scale + RenderOffset.x;
    float y = id.y * Scale + RenderOffset.y;
    float z = id.z * Scale + RenderOffset.z;
    
#if TYPE == 0
	vec2 texelCoord = gl_GlobalInvocationID.xz + RegionSampleOffset;
    vec4 info = texture(RegionsSampler, vec3(texelCoord / RegionsTexSize, float(LodLevel)));
    uint regionId = uint(info.r);
    LayerGroup group = layerGroupings.data[regionId];
    float fade = -5.0 * pow(1.0 - info.g, 10.0);
#if FADE_NEAR_ORIGIN == 1
    float len = distance(vec2(x, z), Origin.xz);
	fade = min(fade, -5.0 * (1.0 - min(max(len - FadeStart, 0.0) / (FadeEnd - FadeStart), 1.0)));
#endif
#elif TYPE == 1
	LayerGroup group = layerGroupings.data[0];
	float len = distance(vec2(x, z), Origin.xz);
	float fade = -5.0 * min(max(len - FadeStart, 0.0) / (FadeEnd - FadeStart), 1.0);
#endif
	fade += micLodSoften(group.Storminess); // Better Simple Clouds: per-cloud-type LOD softening (big vs small)
	vec3 gradient = vec3(0.0);
	float noise = getNoiseForLayerGroup(group, x, y, z, gradient) + fade;
	float storminess = clamp(group.Storminess + fade * 0.1, 0.0, 1.0);
	float brightness = clamp(1.0 - storminess * (1.0 - clamp((y - group.StormStart) / group.StormFadeDistance, 0.0, 1.0)), 0.0, 1.0);
#if STYLE == 1
	gradient = normalize(gradient);
	float strength = dot(gradient, SHADE_DIRECTION) * 0.5 + 0.5;
	brightness = clamp(brightness - strength * 0.1, 0.0, 1.0);
#endif
    if (noise > 0.0)
    {
    	createCube(x, y, z, Scale / 2.0, brightness, fade, group);
    	// === Better Simple Clouds: fill the (otherwise hollow) interior while the camera is inside a cloud. Only solid
    	// cells (noise > 0) are touched, so nothing ever appears outside the actual cloud. Within the view distance we
    	// add translucent haze that thickens with distance; right at the view distance we switch to a SOLID opaque
    	// shell so you genuinely cannot see past it (real geometry -> works under any shaderpack). Everything scales
    	// with MicFillStrength (how deep inside the cloud the camera is) so it fades in/out as you enter and leave.
    	// Only ever fill cells createCube left HOLLOW. A surface cell already has an opaque face at exactly this
    	// position and radius, and adding the haze cube (or the shell) on top of it puts two surfaces at the same
    	// depth: they are built from different meshes, so the depth test picks a different winner per pixel and per
    	// frame and the seam shimmers - the "weird faces" pattern, visible wherever a cloud surface came within the
    	// fill radius. See micHasOpaqueFace. Genuinely hollow cells emit no opaque geometry at all, so filling those
    	// (which is what "fill the hollow interior" always meant) can never collide with anything.
    	if (MicFillStrength > 0.0 && !micHasOpaqueFace(x, y, z, group, fade))
    	{
    		float micDist = distance(vec3(x, y, z), Origin);
    		if (micDist < MicViewDist)
    		{
#if TRANSPARENCY == 1
    			// Translucent haze at a CONSTANT per-cell density, so it accumulates into an exponential fog falloff:
    			// lower MicHazeOpacity = see further, higher = murkier. View distance sets where the haze stops and the
    			// shell sits, NOT how thick the haze is - the two are independent so each can be tuned on its own.
    			float micA = MicFillStrength * MicHazeOpacity;
    			if (micA > 0.003)
    				createTransparentCube(x, y, z, Scale / 2.0, brightness, micA);
#endif
    		}
    		else if (MicShell > 0.5 && micDist < MicViewDist + MIC_SHELL_CELLS)
    		{
    			// Optional opaque view-distance shell: a hard cut-off so you can't see across a huge cloud.
    			createSolidCube(x, y, z, Scale / 2.0, brightness);
    		}
    	}
    }
#if TRANSPARENCY == 1
    else if (group.TransparencyFade > 0.01 && noise > -group.TransparencyFade && noise < 0.0)
    {
   		float length = distance(vec2(x, z), Origin.xz);
   		if (length < TransparencyDistance)
   		{
   			float alpha = 1.0 / group.TransparencyFade * (noise + group.TransparencyFade);
    		createTransparentCube(x, y, z, Scale / 2.0, brightness, alpha);
   		}
    }
#endif
}